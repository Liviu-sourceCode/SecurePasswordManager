{
  "name": "passwordmanager",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build:windows": "tauri build",
    "tauri:build:linux": "NO_STRIP=1 tauri build --bundles appimage",
    "sync-host": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/sync-host.ps1",
    "sync-host:linux": "bash ./tools/sync-host.sh",
    "sync-host:linux:chrome": "bash ./tools/sync-host.sh chrome",
    "sync-host:linux:brave": "bash ./tools/sync-host.sh brave",
    "sync-host:linux:firefox": "bash ./tools/sync-host.sh firefox",
    "build:host": "cargo build --release --manifest-path src-tauri/Cargo.toml && npm run sync-host",
    "build:host:linux": "cargo build --release --manifest-path src-tauri/Cargo.toml && npm run sync-host:linux",
    "build:host:linux:brave": "cargo build --release --manifest-path src-tauri/Cargo.toml && npm run sync-host:linux:brave",
    "build:host:linux:all": "cargo build --release --manifest-path src-tauri/Cargo.toml && npm run sync-host:linux",
    "legal:bundle": "node ./tools/generate-legal-bundle.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.0",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@tauri-apps/cli": "^2.10.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
